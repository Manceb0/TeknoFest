DATABASE_PATH=quismotion.duckdb
AI_PROVIDER=local_yolo
# Detector weights: .pt or exported .onnx. PDR target is yolov8x.pt (use a GPU).
YOLO_MODEL_PATH=yolov8s.pt
YOLO_CONFIDENCE=0.18
YOLO_IMGSZ=512
# "auto" -> CUDA when available (RTX 4060), else CPU. Force with "cuda:0" / "cpu".
DEVICE=auto
EMBEDDING_DIM=512
# Embeddings stay PyTorch so VSS works even when the detector runs as ONNX.
EMBED_MODEL_PATH=yolov8s.pt
ENABLE_DEEPSORT=true
DEFAULT_SPEED_LIMIT=20
# Optional fine-tuned YOLOv8s-cls weights for driver behavior (smoking / phone).
# Leave empty to report behavior honestly as "not_observable".
BEHAVIOR_MODEL_PATH=
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Roboflow integration.
# Get a free key at Roboflow -> Settings -> API Keys -> Private API Key.
# With a behavior project + version set (and BEHAVIOR_MODEL_PATH empty), the live
# pipeline uses Roboflow hosted inference for driver behavior. The defaults below
# point at the cited "Distracted Driving" dataset (set the version you trained/use).
ROBOFLOW_API_KEY=
ROBOFLOW_WORKSPACE=ipylot-project
ROBOFLOW_PROJECT_VEHICLE=
ROBOFLOW_VERSION_VEHICLE=
ROBOFLOW_PROJECT_PLATE=
ROBOFLOW_VERSION_PLATE=
ROBOFLOW_PROJECT_BEHAVIOR=distracted-driving-v2wk5
ROBOFLOW_VERSION_BEHAVIOR=
